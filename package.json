{
  "name": "sequelize-view-builder",
  "version": "1.0.0",
  "description": "Librería para generar vistas SQL complejas reutilizables con Sequelize",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "example": "tsx examples/example-view.ts"
  },
  "keywords": ["sequelize", "sql", "view", "orm", "typescript"],
  "author": "Villalba Ricardo Daniel:ritchieforest",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^7.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "sequelize": "^6.37.0"
  }
}
